---
interface Props {
  transparentOverHero?: boolean;
}

const { transparentOverHero = false } = Astro.props;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/services/', label: 'Services' },
  { href: '/journal/', label: 'Journal' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class:list={['nav', { 'nav--transparent': transparentOverHero }]} data-nav>
  <div class="nav__bar wrap">
    <a href="/" class="nav__mark">Fable and Frame</a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((link) => (
        <a href={link.href} class="label nav__link">{link.label}</a>
      ))}
      <a href="/client-login/" class="label nav__link nav__link--muted">Client Login</a>
    </nav>

    <button type="button" class="nav__toggle" data-nav-toggle aria-expanded="false" aria-controls="mobile-menu">
      <span class="visually-hidden">Open menu</span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" data-mobile-menu>
  <nav class="mobile-menu__links" aria-label="Mobile">
    {links.map((link) => (
      <a href={link.href} class="mobile-menu__link">{link.label}</a>
    ))}
    <a href="/client-login/" class="mobile-menu__link mobile-menu__link--label label">Client Login</a>
  </nav>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background: var(--color-ivory);
    transition: background-color 0.3s var(--ease-out-quart);
  }

  .nav--transparent {
    background: linear-gradient(to bottom, oklch(10% 0.01 250 / 0.55) 0%, oklch(10% 0.01 250 / 0) 100%);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
  }

  .nav--transparent.nav--scrolled {
    background: var(--color-ivory);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .nav__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
  }

  @media (max-width: 640px) {
    .nav__bar {
      padding: var(--space-sm);
    }
  }

  .nav__mark {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-ink);
    transition: color 0.3s var(--ease-out-quart);
  }

  .nav--transparent:not(.nav--scrolled) .nav__mark {
    color: var(--color-ivory-on-dark);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  @media (max-width: 900px) {
    .nav__links {
      display: none;
    }
  }

  .nav__link {
    text-decoration: none;
    color: var(--color-ink);
    transition: color 0.3s var(--ease-out-quart);
  }

  .nav--transparent:not(.nav--scrolled) .nav__link {
    color: var(--color-ivory-on-dark);
  }

  .nav__link--muted {
    opacity: 0.6;
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: var(--space-xs);
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .nav__toggle {
      display: flex;
    }
  }

  .nav__toggle-bar {
    width: 22px;
    height: 1.5px;
    background: currentColor;
    color: var(--color-ink);
    transition: background-color 0.3s var(--ease-out-quart);
  }

  .nav--transparent:not(.nav--scrolled) .nav__toggle-bar {
    background: var(--color-ivory-on-dark);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--color-cinematic-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(100%);
    transition: transform 0.4s var(--ease-out-quart);
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  .mobile-menu__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-ivory-on-dark);
    text-decoration: none;
  }

  .mobile-menu__link--label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    opacity: 0.7;
  }
</style>

<script>
  const nav = document.querySelector('[data-nav]');
  const toggle = document.querySelector('[data-nav-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');

  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('nav--scrolled', window.scrollY > 80);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }
</script>
