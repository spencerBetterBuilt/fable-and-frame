---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Each shoot gets its own individual Pixieset gallery link (sent directly to the client) rather
// than a single shared login URL — there's no confirmed general portal link to send people to yet.
// If Madyson turns on Pixieset's "Homepage" client-portal feature, this can link there directly;
// see IMAGE-SHOTLIST.md/session notes for the follow-up.
---

<BaseLayout
  title="Client Login | Fable and Frame Studio"
  description="Find your private Fable and Frame Studio client gallery, hosted on Pixieset."
  noindex
>
  <section class="section login">
    <div class="wrap login__inner">
      <p class="label login__eyebrow">Client Login</p>
      <h1>Your Gallery Lives on Pixieset</h1>
      <p class="login__body">
        Client galleries, proofing, and downloads are hosted on Pixieset, not on this site. Your
        gallery link was sent directly to you by email after your session — check your inbox (and
        spam folder) for a message from Pixieset.
      </p>
      <a class="cta" href="/contact/">Can't find your link? Reach out</a>
      <p class="login__help">Include your name and event date and we'll resend it.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .login {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .login__inner {
    max-width: 56ch;
  }

  .login__eyebrow {
    color: var(--color-sage-deep);
    margin-bottom: var(--space-xs);
  }

  .login h1 {
    margin-bottom: var(--space-sm);
  }

  .login__body {
    opacity: 0.85;
    margin-bottom: var(--space-md);
  }

  .cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    padding: 18px 40px;
    border: 1px solid var(--color-ink);
    background: var(--color-ink);
    color: var(--color-ivory);
    transition: background-color 0.25s var(--ease-out-quart);
  }

  .cta:hover {
    background: var(--color-cinematic-dark);
  }

  .login__help {
    margin-top: var(--space-md);
    opacity: 0.65;
  }
</style>
